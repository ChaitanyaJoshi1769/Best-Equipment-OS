PORT=3003
NODE_ENV=development

# Salesforce
SALESFORCE_API_KEY=your_salesforce_api_key
SALESFORCE_ENDPOINT=https://your-instance.salesforce.com

# SAP ERP
SAP_API_KEY=your_sap_api_key
SAP_ENDPOINT=https://your-sap-instance.com

# Telematics
TELEMATICS_API_KEY=your_telematics_api_key
TELEMATICS_ENDPOINT=https://telematics-provider.com

# Twilio
TWILIO_API_KEY=your_twilio_account_sid:your_auth_token
TWILIO_ENDPOINT=https://api.twilio.com/2010-04-01

# Webhooks
WEBHOOK_SECRET=your_webhook_secret
