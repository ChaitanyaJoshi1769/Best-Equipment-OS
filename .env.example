# Environment Configuration - Best Equipment OS

# Application
NODE_ENV=development
APP_NAME=best-equipment-os
API_PORT=3001
WEB_PORT=3000
MOBILE_PORT=8081

# Database
DATABASE_URL=postgresql://postgres:password@postgres:5432/best_equipment_dev
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
REDIS_URL=redis://redis:6379

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=24h
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-change-in-production
REFRESH_TOKEN_EXPIRATION=7d

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=best-equipment-os-uploads

# Kafka/RabbitMQ
KAFKA_BROKERS=kafka:9092
RABBIT_URL=amqp://guest:guest@rabbitmq:5672

# Integrations
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REDIRECT_URI=http://localhost:3001/auth/salesforce/callback

M5_API_KEY=
M5_ENDPOINT=https://api.m5.com

SAMSARA_API_KEY=
GEOTAB_CLIENT_ID=
GEOTAB_CLIENT_SECRET=

# Email
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@bestequipment.com

# Logging & Observability
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
PROMETHEUS_PORT=9090

# Third-party APIs
MAPBOX_ACCESS_TOKEN=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Feature flags
FEATURE_PREDICTIVE_MAINTENANCE=true
FEATURE_ADVANCED_ANALYTICS=true
FEATURE_MOBILE_APP=true
